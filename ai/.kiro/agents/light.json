{
  "name": "light",
  "description": "General-purpose agent for answering questions, looking things up, and making small changes",
  "model": "claude-opus-4.8",
  "tools": ["*"],
  "allowedTools": [
    "@builtin",
    "fs_*",
    "use_subagent",
    "execute_bash",
    "@context7",
    "@exa",
    "@atlassian",
    "@figma-developer-mcp",
    "@git",
    "@chrome-devtools"
  ],
  "toolsSettings": {
    "subagent": {
      "availableAgents": [
        "designer",
        "explorer",
        "reviewer",
        "simplifier",
        "tester",
        "debugger",
        "planner",
        "researcher",
        "worker",
        "council-master",
        "councillor-a",
        "councillor-b",
        "councillor-c"
      ],
      "trustedAgents": [
        "designer",
        "explorer",
        "reviewer",
        "simplifier",
        "tester",
        "debugger",
        "planner",
        "researcher",
        "worker",
        "council-master",
        "councillor-a",
        "councillor-b",
        "councillor-c"
      ]
    }
  },
  "hooks": {
    "stop": [
      {
        "command": "~/.kiro/hooks/cmux-notify.sh",
        "description": "Notify via cmux when response completes"
      }
    ],
    "postToolUse": [
      {
        "matcher": "fs_write",
        "command": "~/.kiro/hooks/post-write-format.sh"
      }
    ]
  },
  "resources": [
    "file:///Users/peanu/.kiro/steering/*.md",
    "file:///Users/peanu/.kiro/skills/*/SKILL.md",

    "file://.kiro/steering/*.md",
    "skill://.kiro/skills/*/SKILL.md",

    "file://README.md",
    "file://package.json"
  ],
  "prompt": "file:///Users/peanu/.kiro/agents/light.md",
  "includeMcpJson": true
}
