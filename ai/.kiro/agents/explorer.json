{
  "name": "explorer",
  "description": "Explorer Agent that investigates codebases, reads documentation, and researches library usage via Context7",
  "model": "claude-opus-4.8",
  "tools": ["*"],
  "allowedTools": ["@builtin", "fs_*", "execute_bash", "@context7", "@exa"],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "write",
        "command": "~/.kiro/hooks/plan_writers/validate-artifact-plan-write.js"
      }
    ]
  },
  "resources": [
    "file:///Users/peanu/.kiro/steering/*.md",
    "file:///Users/peanu/.kiro/skills/*/SKILL.md",

    "file://.kiro/steering/*.md",
    "skill://.kiro/skills/*/SKILL.md"
  ],
  "prompt": "file:///Users/peanu/.kiro/agents/explorer.md",
  "includeMcpJson": true
}
