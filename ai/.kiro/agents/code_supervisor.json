{
  "name": "code_supervisor",
  "description": "Coding Supervisor Agent that plans and delegates tasks to specialized agents",
  "model": "claude-opus-4.6",
  "tools": ["*"],
  "allowedTools": ["@builtin", "fs_*", "execute_bash", "use_subagent"],
  "toolsSettings": {
    "subagent": {
      "availableAgents": [
        "designer",
        "developer",
        "explorer",
        "reviewer",
        "simplifier",
        "tester",
        "debugger",
        "planner",
        "librarian",
        "researcher",
        "council-master",
        "councillor-a",
        "councillor-b",
        "councillor-c"
      ],
      "trustedAgents": [
        "designer",
        "developer",
        "explorer",
        "reviewer",
        "simplifier",
        "tester",
        "debugger",
        "planner",
        "librarian",
        "researcher",
        "council-master",
        "councillor-a",
        "councillor-b",
        "councillor-c"
      ]
    }
  },
  "hooks": {
    "stop": [
      {
        "command": "~/.kiro/hooks/cmux-notify.sh",
        "description": "Notify via cmux when response completes"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "~/.kiro/hooks/phase-reminder.sh"
      }
    ]
  },
  "resources": [
    "file:///Users/peanu/.kiro/steering/*.md",
    "file:///Users/peanu/.kiro/skills/*/SKILL.md",

    "file://.kiro/steering/*.md",
    "skill://.kiro/skills/*/SKILL.md"
  ],
  "prompt": "file:///Users/peanu/.kiro/agents/code_supervisor.md",
  "includeMcpJson": false
}
