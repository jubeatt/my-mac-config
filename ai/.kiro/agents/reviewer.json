{
  "name": "reviewer",
  "description": "Code Reviewer Agent that performs thorough code reviews and ensures quality standards",
  "model": "claude-opus-4.8",
  "tools": ["*"],
  "allowedTools": ["@builtin", "fs_*", "execute_bash"],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "write",
        "command": "~/.kiro/hooks/plan_writers/validate-artifact-plan-write.js"
      }
    ]
  },
  "resources": [
    "file:///Users/peanu/.kiro/steering/*.md",
    "file:///Users/peanu/.kiro/skills/*/SKILL.md",

    "file://.kiro/steering/*.md",
    "skill://.kiro/skills/*/SKILL.md"
  ],
  "prompt": "file:///Users/peanu/.kiro/agents/reviewer.md",
  "includeMcpJson": false
}
